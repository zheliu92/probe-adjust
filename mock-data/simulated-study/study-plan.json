{
  "study": {
    "id": "default",
    "title": "Smart Home Controller UX Study",
    "description": "A 2-condition experience-focused mixed-methods study comparing two UI designs (Dashboard vs. Voice-First) for a smart home controller. Participants complete tasks under each condition. Post-experience interview probes subjective experience and trust."
  },
  "blocks": [
    {
      "type": "plain",
      "label": "Introduction & Consent",
      "position": 0,
      "slots": []
    },
    {
      "type": "feedback",
      "label": "Demographic Survey",
      "position": 1,
      "slots": [
        {
          "name": "Demographic Questionnaire",
          "data_type": "quantitative",
          "data_nature": "subjective",
          "slot_kind": "template",
          "template_file": "demographic_survey_template.txt"
        },
        {
          "name": "Demographic Responses",
          "data_type": "quantitative",
          "data_nature": "subjective",
          "slot_kind": "data"
        }
      ]
    },
