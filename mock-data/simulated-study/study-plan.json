      "label": "Condition A — Dashboard UI",
      "position": 3,
      "slots": [
        {
          "name": "System Log",
          "data_type": "quantitative",
          "data_nature": "objective",
          "slot_kind": "data",
          "annotation": "Focus on task completion times, error counts, and retry events. T= timestamps are in seconds from session start."
        },
        {
          "name": "Think-Aloud Transcript",
          "data_type": "qualitative",
          "data_nature": "subjective",
          "slot_kind": "data",
          "annotation": "Utterances prefixed with [confusion] or [positive] indicate researcher-coded valence. Pay particular attention to mentions of control, trust, or confusion."
        },
        {
          "name": "Observation Notes",
          "data_type": "qualitative",
          "data_nature": "subjective",
          "slot_kind": "data",
          "annotation": "Researcher field notes. Lines marked [!] indicate moments the researcher flagged as notable during the session."
        }
      ]
    },
    {
      "type": "feedback",
      "label": "Post-Condition A Survey",
      "position": 4,
      "slots": [
