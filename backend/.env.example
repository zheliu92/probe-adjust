# Database
# SQLite (local default): sqlite:///./probe_adjust.db
# PostgreSQL (cloud):     postgresql://user:password@host:5432/probe_adjust
DATABASE_URL=sqlite:///./probe_adjust.db

# File storage
# local (default) or s3
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads

# Interaction logs directory
LOG_DIR=./logs

# OpenAI API key — set to "placeholder" to use mock responses
OPENAI_API_KEY=placeholder

# CORS origin for frontend (change if frontend runs on different port)
FRONTEND_ORIGIN=http://localhost:5173

# Additional CORS origins — comma-separated (e.g. your GitHub Pages URL)
# EXTRA_ORIGINS=https://yourname.github.io

# Cloud storage (only needed when STORAGE_BACKEND=s3)
# S3_BUCKET=your-bucket-name
# AWS_REGION=us-east-1
