# Copy to .env.production and fill in your values, OR set as GitHub Actions secrets.
# These are injected at build time by Vite (prefix VITE_ makes them public).

# Full URL of your Render backend including /api suffix
# e.g. https://probe-adjust-api.onrender.com/api
VITE_API_BASE_URL=https://YOUR_RENDER_APP.onrender.com/api

# GitHub Pages base path — must match your repo name with leading and trailing slash
# e.g. /probe-adjust/
VITE_BASE_PATH=/probe-adjust/
